---
import ContentShell from "../components/layout/ContentShell.astro";
import { site } from "../config/site";
import "../style/pages/write.css";

const title = `Write - ${site.site.name}`;
const description = "Write and publish from the browser";
---

<ContentShell
  variant="article"
  background="content"
  title={title}
  description={description}
  ogType="website"
  contentClass="content-page content-page--article content-page--write"
  contentAriaLabel="Write content"
  tocAriaLabel="Write table of contents"
>
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <div class="write-page" data-write-root>
    <header class="content-page-header">
      <h1 id="write-title" class="content-page-title">Write</h1>
      <p class="content-page-description">
        Draft posts and moments in the browser; every publish deploys
        automatically
      </p>
    </header>

    <button
      type="button"
      class="write-button write-button--logout"
      data-write-logout
      hidden
    >
      Sign out
    </button>

    <section class="write-panel" data-write-auth hidden>
      <h2 class="write-panel__title">Authentication</h2>
      <p class="write-page__hint">
        Paste your GitHub App private key (PEM). The key is encrypted and kept
        only in this browser session — it is never uploaded to any server.
      </p>
      <textarea
        class="write-textarea write-textarea--pem"
        data-write-pem
        rows="8"
        autocomplete="off"
        spellcheck="false"
        placeholder="-----BEGIN RSA PRIVATE KEY-----"></textarea>
      <div class="write-actions">
        <button
          type="button"
          class="write-button write-button--primary"
          data-write-auth-save
        >
          Save key
        </button>
        <button type="button" class="write-button" data-write-pem-import>
          Import from file
        </button>
        <input
          type="file"
          accept=".pem,.key,.txt,application/x-pem-file,text/plain"
          data-write-pem-file
          hidden
        />
      </div>
    </section>

    <section class="write-panel" data-write-editor hidden>
      <nav class="write-tabs" aria-label="Writing panels">
        <button type="button" class="write-tab is-active" data-write-tab="edit">
          Post
        </button>
        <button type="button" class="write-tab" data-write-tab="moment">
          Moment
        </button>
        <button type="button" class="write-tab" data-write-tab="manage">
          Manage
        </button>
      </nav>

      <div data-write-panel="edit">
        <form class="write-form" data-write-form novalidate>
          <div class="write-form__grid">
            <label class="write-field">
              <span class="write-field__label">Title</span>
              <input
                class="write-input"
                type="text"
                data-write-field="title"
                required
              />
            </label>
            <label class="write-field">
              <span class="write-field__label">Slug (file name)</span>
              <input
                class="write-input"
                type="text"
                data-write-field="slug"
                placeholder="Generated from title if empty"
              />
            </label>
            <label class="write-field">
              <span class="write-field__label">Archive folder</span>
              <input
                class="write-input"
                type="text"
                data-write-field="archiveDir"
                placeholder="e.g. 2026; empty = root"
              />
            </label>
            <label class="write-field">
              <span class="write-field__label">Created date</span>
              <input
                class="write-input"
                type="date"
                data-write-field="createdAt"
              />
            </label>
            <label class="write-field">
              <span class="write-field__label">Type label</span>
              <input
                class="write-input"
                type="text"
                data-write-field="type"
                placeholder="e.g. Tech / Life, optional"
              />
            </label>
            <label class="write-field">
              <span class="write-field__label">File format</span>
              <select class="write-input" data-write-field="fileFormat">
                <option value="md">Markdown (.md)</option>
                <option value="mdx">MDX (.mdx)</option>
              </select>
            </label>
            <label class="write-field write-field--full">
              <span class="write-field__label">Description</span>
              <textarea
                class="write-textarea"
                data-write-field="description"
                rows="2"></textarea>
            </label>
            <label class="write-field write-field--full">
              <span class="write-field__label">Cover</span>
              <input
                class="write-input"
                type="text"
                data-write-field="cover"
                placeholder="https:// image URL, or pick “Use as cover” below"
              />
            </label>
            <label class="write-field write-field--inline">
              <input type="checkbox" data-write-field="published" checked />
              <span class="write-field__label"
                >Public (uncheck to keep as a hidden draft)</span
              >
            </label>
          </div>

          <div class="write-images">
            <div class="write-actions">
              <button type="button" class="write-button" data-write-image-add>
                Add images
              </button>
              <input
                type="file"
                accept="image/*"
                multiple
                data-write-image-input
                hidden
              />
            </div>
            <ul class="write-image-list" data-write-image-list></ul>
          </div>

          <label class="write-field write-field--full">
            <span class="write-field__label">Body (Markdown)</span>
            <textarea
              class="write-textarea write-textarea--body"
              data-write-field="body"
              rows="18"
              spellcheck="false"></textarea>
          </label>

          <div class="write-actions">
            <button
              type="submit"
              class="write-button write-button--primary"
              data-write-publish
            >
              Publish post
            </button>
            <button type="button" class="write-button" data-write-reset>
              New / Reset
            </button>
          </div>
        </form>
      </div>

      <div data-write-panel="moment" hidden>
        <label class="write-field write-field--full">
          <span class="write-field__label">Moment (Markdown)</span>
          <textarea
            class="write-textarea"
            data-write-moment-content
            rows="6"
            placeholder="What's on your mind?"></textarea>
        </label>
        <label class="write-field write-field--full">
          <span class="write-field__label">Tags</span>
          <input
            class="write-input"
            type="text"
            data-write-moment-tags
            placeholder="Comma separated, optional"
          />
        </label>
        <div class="write-actions">
          <button
            type="button"
            class="write-button"
            data-write-moment-image-add
          >
            Add images
          </button>
          <input
            type="file"
            accept="image/*"
            multiple
            data-write-moment-image-input
            hidden
          />
          <button
            type="button"
            class="write-button write-button--primary"
            data-write-moment-publish
          >
            Post moment
          </button>
        </div>
        <ul class="write-image-list" data-write-moment-image-list></ul>
      </div>

      <div data-write-panel="manage" hidden>
        <div class="write-actions">
          <button type="button" class="write-button" data-write-refresh>
            Refresh list
          </button>
        </div>
        <ul class="write-article-list" data-write-article-list></ul>
      </div>
    </section>

    <p class="write-status" role="status" data-write-status></p>
  </div>
</ContentShell>

<script>
  import { initWritePage } from "../scripts/write-page";

  document.addEventListener("astro:page-load", () => initWritePage());
</script>
